{
  "name": "@augment-adk/augment-adk",
  "version": "0.1.0",
  "description": "A standalone Agent Development Kit for LlamaStack Responses API multi-agent orchestration",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "adk",
    "agent",
    "multi-agent",
    "llamastack",
    "responses-api",
    "mcp",
    "orchestration",
    "tool-calling",
    "hitl",
    "guardrails"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/augment-adk/augment-adk.git"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "~5.4.0",
    "vitest": "^2.0.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  }
}
