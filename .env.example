# Augment ADK — Environment Variables
#
# Copy this file to .env and fill in the values for your environment.

# LlamaStack server URL (required for LlamaStack examples)
LLAMA_STACK_URL=http://localhost:8321

# Model identifier for LlamaStack
LLAMA_STACK_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Generic model name (used by some examples)
MODEL=meta-llama/Llama-3.1-8B-Instruct

# OpenAI-compatible endpoint (for chat-completions example)
# OPENAI_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=

# TLS verification (set to "true" to skip for self-signed certs in development)
# SKIP_TLS_VERIFY=false
